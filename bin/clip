#!/usr/bin/env bash

#######################################
# Copy buffer to the system's clipboard.
# Usage:
# clip foo.txt
# cat foo.txt | clip
#######################################

source utils.sh

if [[ $# -eq 0 ]]; then
	input=$(</dev/stdin)
elif [[ -f "$1" ]]; then
	input=("$(cat "$1")")
else
	input=("$@")
fi

if has_cmd wl-copy; then
	# wl-clipboard https://github.com/bugaevc/wl-clipboard
	echo -n "${input[@]}" | wl-copy
elif has_cmd xclip; then
	echo -n "${input[@]}" | xclip -sel clip
elif has_cmdtermux-clipboard-set; then
	echo -n "${input[@]}" | termux-clipboard-set
else
	echo "Error: Unable to find a program to send the data to the clipboard"
fi
